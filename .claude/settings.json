{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "WebSearch",
      "WebFetch",
      "Task",
      "Bash(mkdir:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(node:*)",
      "Bash(npm run build)",
      "Bash(npm run lint)",
      "Bash(npm run dev)",
      "Bash(npx:*)",
      "Bash(python3:*)",
      "Bash(pip install:*)",
      "Bash(git status)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git push:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./**/.env)",
      "Bash(rm -rf /*)",
      "Bash(curl:* /dev/tcp*)"
    ]
  },
  "//": "Uwaga: allowlisty NARZĘDZI per-agent są w YAML frontmatter każdego pliku .claude/agents/*.md (np. web-builder nie ma dostępu do wysyłki maili, deployer tylko do Vercel MCP). Ten plik ustawia globalne uprawnienia projektu tak, by pipeline szedł nieinteraktywnie. Dla crona i tak używa się flagi --dangerously-skip-permissions (patrz README)."
}
