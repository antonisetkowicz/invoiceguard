        "jsonBody": "={{ { type: 'FRAUD_RISK', severity: 'high', title: 'Critical Fraud Risk Detected', description: $json.riskFactors.join('; '), amountAtRisk: $json.amount, organizationId: $json.organizationId } }}",
        "sendHeaders": true,
