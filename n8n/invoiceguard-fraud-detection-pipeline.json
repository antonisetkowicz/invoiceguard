{
  "name": "InvoiceGuard – Automated Invoice Fraud Detection & Approval Pipeline",
  "nodes": [
    {
      "id": "142ad6c5-bc88-4159-9254-336b47eb027a",
      "name": "Note 1",
      "type": "n8n-nodes-base.stickyNote",
