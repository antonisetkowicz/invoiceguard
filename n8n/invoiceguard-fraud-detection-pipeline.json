        "jsCode": "const stats = $('Fetch Dashboard Metrics').item.json.data;\nconst alerts = $json.data.alerts || [];\nconst summary = $json.data.summary;\n\nconst topVendorsHtml = stats.topVendors.slice(0, 5)\n  .map(v => `<li>${v.vendor} — $${v.amount.toFixed(2)} (${v.invoiceCount} invoices)</li>`).join('');\n\nconst html = `\n  <h2>InvoiceGuard Daily Digest</h2>\n  <p><b>Total invoices:</b> ${stats.totalInvoices} | <b>Total spend:</b> $${stats.totalSpend.toFixed(2)}</p>\n  <p><b>Open alerts:</b> ${summary.open} | <b>Amount at risk:</b> $${summary.totalAmountAtRisk.toFixed(2)}</p>\n  <h3>Top vendors by spend</h3><ul>${topVendorsHtml}</ul>\n`;\n\nreturn [{ json: { html, stats, summary, alertCount: alerts.length } }];"
      }
