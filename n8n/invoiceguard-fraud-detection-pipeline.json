    {
      "id": "5f496eff-ca97-4718-8804-3adbe6c9f581",
      "name": "Duplicate Detection",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1660,
        -80
      ],
      "parameters": {
        "jsCode": "// Re-implements InvoiceGuard's audit-engine duplicate heuristic:\n// vendor-name similarity (Levenshtein-based) + exact amount match + 30-day window.\nfunction stringSimilarity(a, b) {\n  a = (a || '').toLowerCase().trim();\n  b = (b || '').toLowerCase().trim();\n  if (!a || !b) return 0;\n  if (a === b) return 1;\n  const m = a.length, n = b.length;\n  const dp = Array.from({ length: m + 1 }, (_, i) => [i, ...Array(n).fill(0)]);\n  for (let j = 0; j <= n; j++) dp[0][j] = j;\n  for (let i = 1; i <= m; i++) {\n    for (let j = 1; j <= n; j++) {\n      dp[i][j] = a[i - 1] === b[j - 1]\n        ? dp[i - 1][j - 1]\n        : 1 + Math.min(dp[i - 1][j - 1], dp[i - 1][j], dp[i][j - 1]);\n    }\n  }\n  return 1 - dp[m][n] / Math.max(m, n);\n}\n\nconst candidate = $('Validate Schema').item.json;\nconst history = $json.data || [];\nconst dayMs = 24 * 60 * 60 * 1000;\n\nlet best = { similarity: 0, matchedInvoiceId: null };\nfor (const existing of history) {\n  const vendorSim = stringSimilarity(candidate.vendorName, existing.vendorName);\n  const amountMatch = Math.abs(existing.amount - candidate.amount) < 0.01;\n  const numberSim = stringSimilarity(candidate.invoiceNumber, existing.invoiceNumber);\n  const dateDiff = Math.abs(new Date(candidate.issueDate) - new Date(existing.issueDate));\n  const withinWindow = dateDiff < 30 * dayMs;\n\n  if (vendorSim > 0.85 && amountMatch && withinWindow) {\n    const similarity = (vendorSim + (numberSim > 0.7 ? 0.3 : 0)) / 1.3;\n    if (similarity > best.similarity) best = { similarity, matchedInvoiceId: existing.id };\n  }\n}\n\nreturn [{\n  json: {\n    ...candidate,\n    vendorHistory: history,\n    duplicateScore: Math.round(best.similarity * 100),\n    duplicateMatchId: best.matchedInvoiceId,\n  },\n}];"
      }
    },
    {
      "id": "fd4eca97-ad5e-4acf-a9b8-db0740da53e2",
      "name": "Statistical Anomaly Detection",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1920,
        -80
      ],
      "parameters": {
        "jsCode": "// Per-vendor z-score outlier detection, same logic as audit-engine.ts.\nconst inv = $json;\nconst history = (inv.vendorHistory || []).filter(h => h.vendorName?.toLowerCase().trim() === inv.vendorName.toLowerCase().trim());\n\nlet anomalyScore = 0;\nlet anomalyReason = null;\n\nif (history.length >= 3) {\n  const amounts = history.map(h => h.amount);\n  const mean = amounts.reduce((s, a) => s + a, 0) / amounts.length;\n  const stdDev = Math.sqrt(amounts.reduce((s, a) => s + (a - mean) ** 2, 0) / amounts.length);\n  const z = stdDev > 0 ? Math.abs(inv.amount - mean) / stdDev : 0;\n\n  if (stdDev > 0 && z > 2.5) {\n    anomalyScore = Math.min(100, Math.round(z * 20));\n    anomalyReason = `Amount $${inv.amount.toFixed(2)} is ${inv.amount > mean ? 'significantly higher' : 'significantly lower'} than vendor average $${mean.toFixed(2)} (z=${z.toFixed(2)})`;\n  }\n} else {\n  anomalyReason = 'New or low-history vendor — insufficient data for statistical baseline';\n  anomalyScore = 15;\n}\n\nreturn [{ json: { ...inv, anomalyScore, anomalyReason, isNewVendor: history.length < 3 } }];"
      }
    },
    {
      "id": "d191bf7c-705c-4ab2-8e6f-835e02be8cfc",
      "name": "Fraud Risk Scoring Engine",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2180,
        -80
      ],
      "parameters": {
        "jsCode": "// Combines every upstream signal into a single 0-100 fraud risk score.\nconst inv = $json;\nconst factors = [];\nlet score = 0;\n\nscore += inv.duplicateScore * 0.45;\nif (inv.duplicateScore > 60) factors.push(`Possible duplicate of invoice ${inv.duplicateMatchId} (${inv.duplicateScore}% similarity)`);\n\nscore += inv.anomalyScore * 0.30;\nif (inv.anomalyReason) factors.push(inv.anomalyReason);\n\nconst isRoundAmount = inv.amount % 100 === 0 && inv.amount >= 500;\nif (isRoundAmount) { score += 8; factors.push('Suspiciously round invoice amount'); }\n\nconst issueDay = new Date(inv.issueDate).getDay();\nconst isWeekend = issueDay === 0 || issueDay === 6;\nif (isWeekend) { score += 6; factors.push('Invoice issued on a weekend'); }\n\nif (!inv.purchaseOrderId) { score += 10; factors.push('No purchase order on file'); }\n\nif (inv.isNewVendor) { score += 6; factors.push('New or low-history vendor'); }\n\nif (inv.lineItemMismatch) { score += 12; factors.push('Line item totals do not reconcile with invoice amount'); }\n\nscore = Math.max(0, Math.min(100, Math.round(score)));\nconst riskLevel = score >= 80 ? 'critical' : score >= 40 ? 'medium' : 'low';\n\nreturn [{ json: { ...inv, riskScore: score, riskLevel, riskFactors: factors } }];"
      }
    },
    {
      "id": "13227700-5abc-4b31-8b0a-f346bcde7825",
      "name": "Route by Risk Level",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3.2,
      "position": [
        2440,
        -80
      ],
      "parameters": {
        "mode": "expression",
        "numberOutputs": 3,
        "output": "={{ $json.riskLevel === 'critical' ? 0 : $json.riskLevel === 'medium' ? 1 : 2 }}",
        "options": {}
      },
      "outputConnections": null
    },
    {
      "id": "96336a76-abcb-4071-a7df-500c055ec866",
