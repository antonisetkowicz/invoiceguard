    {
      "id": "ae1078cd-60e9-4112-b2d3-91e2e776eaa0",
      "name": "AI Extract Invoice Data",
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 1.8,
      "position": [
        360,
        -80
      ],
      "parameters": {
        "resource": "text",
        "modelId": {
          "__rl": true,
          "value": "gpt-4o",
          "mode": "list"
        },
        "messages": {
          "values": [
            {
              "role": "system",
              "content": "You are an invoice data extraction engine for InvoiceGuard. Read the attached invoice (image or PDF text) and return ONLY strict JSON with keys: vendorName, invoiceNumber, amount, currency, issueDate (ISO 8601), dueDate (ISO 8601 or null), taxId, lineItems (array of {description, quantity, unitPrice, total}). If a field cannot be read, use null."
            },
            {
              "role": "user",
              "content": "={{ 'Submitted metadata as fallback: ' + JSON.stringify($json) }}"
            }
          ]
        },
        "jsonOutput": true,
        "options": {
          "temperature": 0.1
        }
      },
      "continueOnFail": true
    },
    {
      "id": "d916b09a-b037-4b09-b4ce-6c3f8ec7e22b",
      "name": "Reconcile Extracted + Submitted Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        620,
        -80
      ],
      "parameters": {
        "jsCode": "// Merge AI-extracted fields with the originally submitted metadata.\n// AI output wins for anything the submitter left blank; submitted values\n// win when they disagree with a low-confidence extraction.\nconst submitted = $('Normalize Payload').item.json;\nconst ai = $json.message?.content ? JSON.parse($json.message.content) : ($json.data || {});\n\nconst merged = {\n  organizationId: submitted.organizationId,\n  vendorName: submitted.vendorName || ai.vendorName,\n  invoiceNumber: submitted.invoiceNumber || ai.invoiceNumber,\n  amount: submitted.amount || ai.amount,\n  currency: submitted.currency || ai.currency || 'USD',\n  issueDate: submitted.issueDate || ai.issueDate,\n  dueDate: submitted.dueDate || ai.dueDate || null,\n  purchaseOrderId: submitted.purchaseOrderId || null,\n  taxId: ai.taxId || null,\n  lineItems: ai.lineItems || [],\n  submittedBy: submitted.submittedBy || 'unknown',\n  extractionSource: submitted.fileUrl ? 'ai-document' : 'manual-submission',\n};\n\nconst lineItemTotal = (merged.lineItems || []).reduce((s, li) => s + (li.total || 0), 0);\nmerged.lineItemMismatch = lineItemTotal > 0 && Math.abs(lineItemTotal - merged.amount) > 0.01;\n\nreturn [{ json: merged }];"
      }
    },
    {
      "id": "0bf98115-7a1b-4d5d-b06a-03a1586359f2",
      "name": "Validate Schema",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        880,
        -80
      ],
      "parameters": {
        "jsCode": "// Lightweight schema guard mirroring the InvoiceGuard upload validator.\nconst inv = $json;\nconst errors = [];\n\nif (!inv.vendorName || inv.vendorName.trim().length < 2) errors.push('vendorName missing/too short');\nif (!inv.invoiceNumber) errors.push('invoiceNumber missing');\nif (!inv.amount || isNaN(inv.amount) || inv.amount <= 0) errors.push('amount must be a positive number');\nif (!inv.issueDate || isNaN(Date.parse(inv.issueDate))) errors.push('issueDate is not a valid date');\nif (inv.dueDate && isNaN(Date.parse(inv.dueDate))) errors.push('dueDate is not a valid date');\n\nreturn [{ json: { ...inv, isValid: errors.length === 0, validationErrors: errors } }];"
      }
    },
    {
      "id": "c922584f-603a-459d-91af-010ecf49880e",
      "name": "Valid Data?",
      "type": "n8n-nodes-base.if",
