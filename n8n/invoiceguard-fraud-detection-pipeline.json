    },
    {
      "id": "14ab29b5-c798-4390-abca-311a12213756",
      "name": "Alert Finance & Security Team",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2.2,
      "position": [
        3020,
        -260
      ],
      "parameters": {
        "resource": "message",
        "operation": "post",
        "select": "channel",
        "channelId": {
          "__rl": true,
          "value": "#finance-fraud-alerts",
          "mode": "name"
        },
        "text": "=:rotating_light: *Critical risk invoice* `{{ $json.invoiceNumber }}` from *{{ $json.vendorName }}* (${{ $json.amount }}) scored *{{ $json.riskScore }}/100*.\n\n*Risk factors:*\n{{ $json.riskFactors.map(f => '• ' + f).join('\\n') }}",
        "otherOptions": {
          "mrkdwn": true
        }
      }
