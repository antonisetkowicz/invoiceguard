// https://mozilla.org/MPL/2.0/
// © InvoiceGuard EURUSD Multi-Confluence Bot

//@version=6
strategy("EURUSD Multi-Confluence Bot", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=2, initial_capital=10000, currency=currency.USD, commission_type=strategy.commission.cash_per_order, commission_value=0.5, slippage=1, calc_on_every_tick=false)

// ══════════════════════════════════════════════════════════════════════════════
// INPUTS
// ══════════════════════════════════════════════════════════════════════════════

grpTrend    = "═══ Trend Filter ═══"
ema200Len   = input.int(200, "Trend EMA Length", minval=50, maxval=500, group=grpTrend)
ema50Len    = input.int(50,  "Medium EMA Length", minval=20, maxval=100, group=grpTrend)

grpSignal   = "═══ Signal EMAs ═══"
emaFastLen  = input.int(8,   "Fast EMA", minval=3, maxval=30, group=grpSignal)
emaSlowLen  = input.int(21,  "Slow EMA", minval=10, maxval=50, group=grpSignal)

grpRSI      = "═══ RSI Filter ═══"
rsiLen      = input.int(14,  "RSI Length", minval=5, maxval=30, group=grpRSI)
rsiOB       = input.int(70,  "RSI Overbought", minval=60, maxval=85, group=grpRSI)
rsiOS       = input.int(30,  "RSI Oversold", minval=15, maxval=40, group=grpRSI)

grpMACD     = "═══ MACD Confirmation ═══"
macdFast    = input.int(12,  "MACD Fast", minval=5, maxval=30, group=grpMACD)
macdSlow    = input.int(26,  "MACD Slow", minval=15, maxval=50, group=grpMACD)
macdSignal  = input.int(9,   "MACD Signal", minval=3, maxval=20, group=grpMACD)

grpATR      = "═══ ATR Risk Management ═══"
atrLen      = input.int(14,  "ATR Length", minval=5, maxval=30, group=grpATR)
atrSlMult   = input.float(1.5, "SL Multiplier (ATR)", minval=0.5, maxval=4.0, step=0.1, group=grpATR)
atrTpMult   = input.float(2.5, "TP Multiplier (ATR)", minval=1.0, maxval=6.0, step=0.1, group=grpATR)

grpSession  = "═══ Session Filter ═══"
useSessions = input.bool(true, "Trade Only London + NY Sessions", group=grpSession)
londonStart = input.int(7,   "London Start Hour (UTC)", minval=0, maxval=23, group=grpSession)
londonEnd   = input.int(16,  "London End Hour (UTC)", minval=0, maxval=23, group=grpSession)
nyStart     = input.int(13,  "NY Start Hour (UTC)", minval=0, maxval=23, group=grpSession)
nyEnd       = input.int(21,  "NY End Hour (UTC)", minval=0, maxval=23, group=grpSession)

grpMgmt     = "═══ Trade Management ═══"
useTrailing = input.bool(true, "Use Trailing Stop", group=grpMgmt)
trailATR    = input.float(1.0, "Trailing Stop (ATR)", minval=0.3, maxval=3.0, step=0.1, group=grpMgmt)
maxTrades   = input.int(3,   "Max Open Trades", minval=1, maxval=10, group=grpMgmt)
useBE       = input.bool(true, "Move SL to Break-Even", group=grpMgmt)
beATR       = input.float(1.0, "Break-Even Trigger (ATR)", minval=0.3, maxval=3.0, step=0.1, group=grpMgmt)

grpDate     = "═══ Backtest Range ═══"
startDate   = input.time(timestamp("2020-01-01"), "Start Date", group=grpDate)
endDate     = input.time(timestamp("2026-12-31"), "End Date", group=grpDate)

// ══════════════════════════════════════════════════════════════════════════════
// CALCULATIONS
// ══════════════════════════════════════════════════════════════════════════════

ema200 = ta.ema(close, ema200Len)
ema50  = ta.ema(close, ema50Len)
emaF   = ta.ema(close, emaFastLen)
emaS   = ta.ema(close, emaSlowLen)

rsiVal = ta.rsi(close, rsiLen)

[macdLine, signalLine, histLine] = ta.macd(close, macdFast, macdSlow, macdSignal)

atrVal = ta.atr(atrLen)

// ══════════════════════════════════════════════════════════════════════════════
// SESSION FILTER
// ══════════════════════════════════════════════════════════════════════════════

hourUTC   = hour(time, "UTC")
inLondon  = hourUTC >= londonStart and hourUTC < londonEnd
inNY      = hourUTC >= nyStart and hourUTC < nyEnd
inSession = useSessions ? (inLondon or inNY) : true

// ══════════════════════════════════════════════════════════════════════════════
// DATE FILTER
// ══════════════════════════════════════════════════════════════════════════════

inDateRange = time >= startDate and time <= endDate

// ══════════════════════════════════════════════════════════════════════════════
// TREND CONDITIONS
// ══════════════════════════════════════════════════════════════════════════════

bullTrend = close > ema200 and ema50 > ema200
bearTrend = close < ema200 and ema50 < ema200

// ══════════════════════════════════════════════════════════════════════════════
// SIGNAL CONDITIONS
// ══════════════════════════════════════════════════════════════════════════════

emaCrossUp   = ta.crossover(emaF, emaS)
emaCrossDown = ta.crossunder(emaF, emaS)

rsiLongOK  = rsiVal > rsiOS and rsiVal < rsiOB
rsiShortOK = rsiVal > rsiOS and rsiVal < rsiOB

macdBullish = macdLine > signalLine and histLine > 0
macdBearish = macdLine < signalLine and histLine < 0

// Momentum confirmation: price should be moving in the direction of the trade
bullMomentum = close > open and close > close[1]
bearMomentum = close < open and close < close[1]

// ══════════════════════════════════════════════════════════════════════════════
// ENTRY CONDITIONS (Multi-Confluence)
// ══════════════════════════════════════════════════════════════════════════════

longCondition  = emaCrossUp and bullTrend and rsiLongOK and macdBullish and inSession and inDateRange
shortCondition = emaCrossDown and bearTrend and rsiShortOK and macdBearish and inSession and inDateRange

canTrade = strategy.opentrades < maxTrades

// ══════════════════════════════════════════════════════════════════════════════
// DYNAMIC SL / TP (ATR-based)
// ══════════════════════════════════════════════════════════════════════════════

longSL  = close - (atrVal * atrSlMult)
longTP  = close + (atrVal * atrTpMult)
shortSL = close + (atrVal * atrSlMult)
shortTP = close - (atrVal * atrTpMult)

// ══════════════════════════════════════════════════════════════════════════════
// EXECUTE TRADES
// ══════════════════════════════════════════════════════════════════════════════

if longCondition and canTrade
    strategy.entry("Long", strategy.long)
    strategy.exit("Long Exit", "Long", stop=longSL, limit=longTP, trail_points=useTrailing ? atrVal * trailATR / syminfo.mintick : na, trail_offset=useTrailing ? atrVal * trailATR / syminfo.mintick : na)

if shortCondition and canTrade
    strategy.entry("Short", strategy.short)
    strategy.exit("Short Exit", "Short", stop=shortSL, limit=shortTP, trail_points=useTrailing ? atrVal * trailATR / syminfo.mintick : na, trail_offset=useTrailing ? atrVal * trailATR / syminfo.mintick : na)

// ══════════════════════════════════════════════════════════════════════════════
// BREAK-EVEN LOGIC
// ══════════════════════════════════════════════════════════════════════════════

if useBE and strategy.opentrades > 0
    for i = 0 to strategy.opentrades - 1
        entryPrice = strategy.opentrades.entry_price(i)
        isLong = strategy.opentrades.size(i) > 0
        beTrigger = atrVal * beATR

        if isLong and close >= entryPrice + beTrigger
            strategy.exit("Long BE", "Long", stop=entryPrice + syminfo.mintick)

        if not isLong and close <= entryPrice - beTrigger
            strategy.exit("Short BE", "Short", stop=entryPrice - syminfo.mintick)

// ══════════════════════════════════════════════════════════════════════════════
// PLOTS
// ══════════════════════════════════════════════════════════════════════════════

plot(ema200, "EMA 200", color=color.new(color.white, 20), linewidth=2)
plot(ema50,  "EMA 50",  color=color.new(color.yellow, 20), linewidth=1)
plot(emaF,   "EMA Fast", color=color.new(color.lime, 30), linewidth=1)
plot(emaS,   "EMA Slow", color=color.new(color.red, 30), linewidth=1)

bgcolor(bullTrend ? color.new(color.green, 93) : bearTrend ? color.new(color.red, 93) : na)

plotshape(longCondition and canTrade, "Long Signal", shape.triangleup, location.belowbar, color.new(color.lime, 0), size=size.small)
plotshape(shortCondition and canTrade, "Short Signal", shape.triangledown, location.abovebar, color.new(color.red, 0), size=size.small)

// ══════════════════════════════════════════════════════════════════════════════
// DASHBOARD TABLE
// ══════════════════════════════════════════════════════════════════════════════

var table dash = table.new(position.top_right, 2, 10, bgcolor=color.new(color.black, 70), border_width=1, border_color=color.gray)

if barstate.islast
    table.cell(dash, 0, 0, "Metric", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 0, "Value",  text_color=color.white, text_size=size.small)

    table.cell(dash, 0, 1, "Trend",  text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 1, bullTrend ? "BULLISH" : bearTrend ? "BEARISH" : "NEUTRAL", text_color=bullTrend ? color.lime : bearTrend ? color.red : color.yellow, text_size=size.small)

    table.cell(dash, 0, 2, "RSI",    text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 2, str.tostring(rsiVal, "#.#"), text_color=rsiVal > rsiOB ? color.red : rsiVal < rsiOS ? color.lime : color.white, text_size=size.small)

    table.cell(dash, 0, 3, "MACD",   text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 3, macdBullish ? "BULLISH" : macdBearish ? "BEARISH" : "NEUTRAL", text_color=macdBullish ? color.lime : macdBearish ? color.red : color.yellow, text_size=size.small)

    table.cell(dash, 0, 4, "ATR",    text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 4, str.tostring(atrVal, "#.#####"), text_color=color.white, text_size=size.small)

    table.cell(dash, 0, 5, "Session", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 5, inSession ? "ACTIVE" : "CLOSED", text_color=inSession ? color.lime : color.red, text_size=size.small)

    table.cell(dash, 0, 6, "Open Trades", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 6, str.tostring(strategy.opentrades), text_color=color.white, text_size=size.small)

    table.cell(dash, 0, 7, "Win Rate",   text_color=color.white, text_size=size.small)
    totalTrades = strategy.closedtrades
    winTrades   = strategy.wintrades
    winRate     = totalTrades > 0 ? (winTrades / totalTrades) * 100 : 0
    table.cell(dash, 1, 7, str.tostring(winRate, "#.#") + "%", text_color=winRate > 50 ? color.lime : color.red, text_size=size.small)

    table.cell(dash, 0, 8, "Net Profit", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 8, str.tostring(strategy.netprofit, "#.##") + " $", text_color=strategy.netprofit > 0 ? color.lime : color.red, text_size=size.small)

    table.cell(dash, 0, 9, "Profit Factor", text_color=color.white, text_size=size.small)
    pf = strategy.grossloss != 0 ? math.abs(strategy.grossprofit / strategy.grossloss) : 0
    table.cell(dash, 1, 9, str.tostring(pf, "#.##"), text_color=pf > 1 ? color.lime : color.red, text_size=size.small)

// ══════════════════════════════════════════════════════════════════════════════
// ALERTS
// ══════════════════════════════════════════════════════════════════════════════

alertcondition(longCondition and canTrade, "Long Entry", "EURUSD Bot: LONG entry signal")
alertcondition(shortCondition and canTrade, "Short Entry", "EURUSD Bot: SHORT entry signal")
