// This Pine Script™ strategy is subject to the terms of the Mozilla Public License 2.0
// https://mozilla.org/MPL/2.0/
// © InvoiceGuard EURUSD Trend-Pullback Bot v2

//@version=6
strategy("EURUSD Trend-Pullback Bot v2", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=2, initial_capital=10000, currency=currency.USD, commission_type=strategy.commission.cash_per_order, commission_value=0.5, slippage=1, calc_on_every_tick=false, pyramiding=0)

// ══════════════════════════════════════════════════════════════════════════════
// INPUTS
// ══════════════════════════════════════════════════════════════════════════════

grpTrend    = "═══ Trend Filter ═══"
ema200Len   = input.int(200, "Trend EMA Length", minval=50, maxval=500, group=grpTrend)
ema50Len    = input.int(50,  "Medium EMA Length", minval=20, maxval=100, group=grpTrend)

grpPullback = "═══ Pullback Entry ═══"
pullbackEMA = input.int(21,  "Pullback EMA", minval=10, maxval=50, group=grpPullback)
rsiLen      = input.int(7,   "RSI Length", minval=3, maxval=20, group=grpPullback)
rsiOversold = input.int(35,  "RSI Pullback Zone (Long)", minval=15, maxval=45, group=grpPullback)
rsiOverbought = input.int(65, "RSI Pullback Zone (Short)", minval=55, maxval=85, group=grpPullback)

grpATR      = "═══ Risk Management ═══"
atrLen      = input.int(14,  "ATR Length", minval=5, maxval=30, group=grpATR)
atrSlMult   = input.float(2.0, "SL Multiplier (ATR)", minval=1.0, maxval=5.0, step=0.1, group=grpATR)
atrTpMult   = input.float(3.0, "TP Multiplier (ATR)", minval=1.5, maxval=8.0, step=0.1, group=grpATR)

grpSession  = "═══ Session Filter ═══"
useSessions = input.bool(true, "Trade Only London + NY Sessions", group=grpSession)

grpDate     = "═══ Backtest Range ═══"
startDate   = input.time(timestamp("2020-01-01"), "Start Date", group=grpDate)
endDate     = input.time(timestamp("2026-12-31"), "End Date", group=grpDate)

// ══════════════════════════════════════════════════════════════════════════════
// CALCULATIONS
// ══════════════════════════════════════════════════════════════════════════════

ema200 = ta.ema(close, ema200Len)
ema50  = ta.ema(close, ema50Len)
ema21  = ta.ema(close, pullbackEMA)

rsiVal = ta.rsi(close, rsiLen)
atrVal = ta.atr(atrLen)

// ══════════════════════════════════════════════════════════════════════════════
// SESSION FILTER (London 07-16 UTC + NY 13-21 UTC)
// ══════════════════════════════════════════════════════════════════════════════

hourUTC   = hour(time, "UTC")
inLondon  = hourUTC >= 7 and hourUTC < 16
inNY      = hourUTC >= 13 and hourUTC < 21
inSession = useSessions ? (inLondon or inNY) : true
inDateRange = time >= startDate and time <= endDate

// ══════════════════════════════════════════════════════════════════════════════
// TREND DETECTION
// ══════════════════════════════════════════════════════════════════════════════

bullTrend = ema50 > ema200 and close > ema50
bearTrend = ema50 < ema200 and close < ema50

// ══════════════════════════════════════════════════════════════════════════════
// PULLBACK ENTRY LOGIC
//
// LONG: In uptrend, price pulls back to/below EMA 21, RSI dips into
//       oversold zone, then price closes back above EMA 21 (bounce)
// SHORT: Mirror logic for downtrend
// ══════════════════════════════════════════════════════════════════════════════

priceTouchedEMA21Long  = low <= ema21 or low[1] <= ema21[1] or low[2] <= ema21[2]
priceTouchedEMA21Short = high >= ema21 or high[1] >= ema21[1] or high[2] >= ema21[2]

rsiBounced     = rsiVal[1] < rsiOversold and rsiVal > rsiVal[1]
rsiBouncedDown = rsiVal[1] > rsiOverbought and rsiVal < rsiVal[1]

bullishCandle = close > open and close > high[1]
bearishCandle = close < open and close < low[1]

longCondition  = bullTrend and priceTouchedEMA21Long and rsiBounced and bullishCandle and close > ema21 and inSession and inDateRange
shortCondition = bearTrend and priceTouchedEMA21Short and rsiBouncedDown and bearishCandle and close < ema21 and inSession and inDateRange

// ══════════════════════════════════════════════════════════════════════════════
// STORED SL/TP — fixed at entry, never recalculated
// ══════════════════════════════════════════════════════════════════════════════

var float storedLongSL  = na
var float storedLongTP  = na
var float storedShortSL = na
var float storedShortTP = na

noPosition = strategy.position_size == 0

if longCondition and noPosition
    storedLongSL  := close - (atrVal * atrSlMult)
    storedLongTP  := close + (atrVal * atrTpMult)
    strategy.entry("Long", strategy.long)

if shortCondition and noPosition
    storedShortSL := close + (atrVal * atrSlMult)
    storedShortTP := close - (atrVal * atrTpMult)
    strategy.entry("Short", strategy.short)

// ══════════════════════════════════════════════════════════════════════════════
// EXITS — single exit per direction, no conflicts
// ══════════════════════════════════════════════════════════════════════════════

if strategy.position_size > 0
    strategy.exit("Long Exit", "Long", stop=storedLongSL, limit=storedLongTP)

if strategy.position_size < 0
    strategy.exit("Short Exit", "Short", stop=storedShortSL, limit=storedShortTP)

// Close on opposite signal
if strategy.position_size > 0 and shortCondition
    strategy.close("Long", comment="Reverse")

if strategy.position_size < 0 and longCondition
    strategy.close("Short", comment="Reverse")

// ══════════════════════════════════════════════════════════════════════════════
// PLOTS
// ══════════════════════════════════════════════════════════════════════════════

plot(ema200, "EMA 200", color=color.new(color.white, 20), linewidth=2)
plot(ema50,  "EMA 50",  color=color.new(color.yellow, 20), linewidth=1)
plot(ema21,  "EMA 21 (Pullback)", color=color.new(color.aqua, 20), linewidth=1)

bgcolor(bullTrend ? color.new(color.green, 93) : bearTrend ? color.new(color.red, 93) : na)

plotshape(longCondition and noPosition, "Long Signal", shape.triangleup, location.belowbar, color.new(color.lime, 0), size=size.small)
plotshape(shortCondition and noPosition, "Short Signal", shape.triangledown, location.abovebar, color.new(color.red, 0), size=size.small)

// SL/TP lines for current position
plot(strategy.position_size > 0 ? storedLongSL : na, "Long SL", color=color.red, linewidth=1, style=plot.style_linebr)
plot(strategy.position_size > 0 ? storedLongTP : na, "Long TP", color=color.green, linewidth=1, style=plot.style_linebr)
plot(strategy.position_size < 0 ? storedShortSL : na, "Short SL", color=color.red, linewidth=1, style=plot.style_linebr)
plot(strategy.position_size < 0 ? storedShortTP : na, "Short TP", color=color.green, linewidth=1, style=plot.style_linebr)

// ══════════════════════════════════════════════════════════════════════════════
// DASHBOARD
// ══════════════════════════════════════════════════════════════════════════════

var table dash = table.new(position.top_right, 2, 8, bgcolor=color.new(color.black, 70), border_width=1, border_color=color.gray)

if barstate.islast
    table.cell(dash, 0, 0, "Metric", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 0, "Value",  text_color=color.white, text_size=size.small)

    table.cell(dash, 0, 1, "Trend",  text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 1, bullTrend ? "BULL" : bearTrend ? "BEAR" : "FLAT", text_color=bullTrend ? color.lime : bearTrend ? color.red : color.yellow, text_size=size.small)

    table.cell(dash, 0, 2, "RSI " + str.tostring(rsiLen), text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 2, str.tostring(rsiVal, "#.#"), text_color=color.white, text_size=size.small)

    table.cell(dash, 0, 3, "ATR",    text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 3, str.tostring(atrVal, "#.#####"), text_color=color.white, text_size=size.small)

    table.cell(dash, 0, 4, "Session", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 4, inSession ? "ACTIVE" : "CLOSED", text_color=inSession ? color.lime : color.red, text_size=size.small)

    totalTrades = strategy.closedtrades
    winTrades   = strategy.wintrades
    winRate     = totalTrades > 0 ? (winTrades / totalTrades) * 100 : 0.0

    table.cell(dash, 0, 5, "Trades",  text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 5, str.tostring(totalTrades), text_color=color.white, text_size=size.small)

    table.cell(dash, 0, 6, "Win Rate", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 6, str.tostring(winRate, "#.#") + "%", text_color=winRate > 50 ? color.lime : color.red, text_size=size.small)

    table.cell(dash, 0, 7, "Net P&L", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 7, str.tostring(strategy.netprofit, "#.##") + " $", text_color=strategy.netprofit > 0 ? color.lime : color.red, text_size=size.small)

// ══════════════════════════════════════════════════════════════════════════════
// ALERTS
// ══════════════════════════════════════════════════════════════════════════════

alertcondition(longCondition and noPosition, "Long Entry", "EURUSD Bot: LONG entry signal")
alertcondition(shortCondition and noPosition, "Short Entry", "EURUSD Bot: SHORT entry signal")
