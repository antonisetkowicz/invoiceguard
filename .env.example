# ─── InvoiceGuard (istniejący projekt) ───────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/invoiceguard"
JWT_SECRET="change-me-to-a-random-64-char-string"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── autobiznes — sekrety pipeline'u (NIGDY nie commituj .env) ────────
# Marketing / social (marketing-specialist)
AYRSHARE_API_KEY=""          # Ayrshare — publikacja LinkedIn/X/FB
INSTANTLY_API_KEY=""         # Instantly.ai — cold-email (import, nie auto-wysyłka)

# Deploy (deployer) — Vercel MCP zwykle działa przez connector; token opcjonalny
VERCEL_TOKEN=""              # tylko jeśli deploy przez CLI zamiast MCP
VERCEL_TEAM_ID=""

# Analytics (analytics-tracker) — opcjonalne
WINDSOR_API_KEY=""           # Windsor.ai pull danych
SUPERMETRICS_API_KEY=""      # alternatywa dla Windsor.ai

# Alert po runie (cron) — HUMAN_ACTION_REQUIRED niepusty
TELEGRAM_BOT_TOKEN=""        # bot do alertów
TELEGRAM_CHAT_ID=""          # docelowy chat/kanał alertów

# Przełączniki zachowania pipeline'u
AUTOBIZNES_AUTOSEND="false"  # true = pozwól marketing-specialist wysłać 1. batch cold-email bez pytania

# ─── autoodpowiedzi — sekrety pipeline'u odpowiedzi (NIGDY nie commituj .env) ──
# Gmail: autoryzacja przez connector MCP (Gmail) — bez dodatkowych zmiennych.
# UWAGA: Gmail MCP nie ma narzędzia do wysyłki, tylko create_draft/update_draft
# — auto-send dla e-maila nie jest dziś technicznie możliwy (patrz auto-sender.md).

# WhatsApp — wybór integracji: "twilio" (domyślna, bezpieczniejsza, WhatsApp
# Business API) albo "local" (opcja B, nieoficjalna biblioteka typu
# whatsapp-web.js/Baileys na koncie prywatnym, wymaga osobnego procesu Node)
WHATSAPP_INTEGRATION="twilio"

# Opcja A — Twilio WhatsApp Business API
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_NUMBER=""     # format: whatsapp:+48XXXXXXXXX

# Opcja B — lokalny most (whatsapp-web.js / Baileys), patrz README.autoodpowiedzi.md
WHATSAPP_LOCAL_BRIDGE_URL="http://localhost:3900"

# Alert natychmiastowy przy wiadomości sensitivity=high — używa tych samych
# TELEGRAM_BOT_TOKEN / TELEGRAM_CHAT_ID zdefiniowanych wyżej w sekcji autobiznes.
